{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "DocAgent",
  "version": "1.0.6",
  "identifier": "docagent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:9527",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DocAgent - AI文档处理Agent",
        "width": 960,
        "height": 600,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https: http://localhost:* http://127.0.0.1:*; img-src 'self' data: asset: https:; worker-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "resources": {
      "../sidecar_dist/": "sidecar_dist/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis/installer-hooks.nsh",
        "template": "nsis/installer.nsi"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFDMjdCMzEwMkY5RTNEMjEKUldRaFBaNHZFTE1uckVFWVVnaXJ5MXB6NExERU1vQmNrL29kb0tHNUFMeU04eUo2VDMvUS9iYm4K",
      "endpoints": [
        "https://docagent-proxy.workers.dev/latest.json",
        "https://github.com/XuMingKe-06/DocAgent/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
